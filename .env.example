# ========================================
# Sanaathrumylens - Environment Variables
# ========================================
# Copy this file to .env.local and fill in the values.
# On Vercel, add these in Project Settings > Environment Variables.
# ALL values below are REQUIRED for the site to work with a database.

# MySQL Database (required)
DB_HOST=your-db-host.example.com
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

# JWT Authentication (required - use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-here

# Site Configuration (optional - has defaults)
SITE_NAME=Sanaathrumylens
SITE_URL=https://www.sanaathrumylens.co.ke

# Google AdSense (optional - leave empty to disable ads)
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=
